# Optional overrides. If unset, the app defaults to:
# - REPO_SCANNER_PROJECTS_ROOT=~/Developer/Projects
# - REPO_SCANNER_CODEX_ROOT=~/.codex
# - REPO_SCANNER_CURSOR_WORKSPACES=~/Library/Application Support/Cursor/User/workspaceStorage
# Only repos under REPO_SCANNER_PROJECTS_ROOT are included in the dashboard.
REPO_SCANNER_PROJECTS_ROOT=/absolute/path/to/your/repos
REPO_SCANNER_CODEX_ROOT=/absolute/path/to/your/.codex
REPO_SCANNER_CURSOR_WORKSPACES=/absolute/path/to/Cursor/User/workspaceStorage

# Keep the app local-only unless you already have your own auth boundary in front of it.
REPO_SCANNER_ALLOW_REMOTE=false

# Optional Cursor Admin API settings
CURSOR_ADMIN_API_KEY=
CURSOR_TEAM_ID=
CURSOR_STATS_LOOKBACK_DAYS=30
